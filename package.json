{
  "name": "agendalab-playwright-portfolio",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright playwright test",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright playwright test",
    "test:headed": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright playwright test --headed",
    "report": "playwright show-report",
    "install:browsers": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright playwright install chromium",
    "test:bdd": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright cucumber-js",
    "test:bdd:headed": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright HEADED=true cucumber-js",
    "test:bdd:smoke": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright cucumber-js --tags '@smoke'",
    "test:bdd:regression": "cross-env PLAYWRIGHT_BROWSERS_PATH=.ms-playwright cucumber-js --tags '@regression'"
  },
